@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to School Library System</h1>
    <p class="lead">Your digital gateway to the school's book collection</p>
    <hr class="my-4" />

    @if (User.Identity?.IsAuthenticated == true)
    {
        @if (User.IsInRole("Student"))
        {
            <p>Browse and request books from our collection.</p>
            <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-lg">Browse Books</a>
            <a asp-controller="Requests" asp-action="MyRequests" class="btn btn-outline-primary btn-lg">My Requests</a>
        }
        else if (User.IsInRole("Librarian"))
        {
            <p>Manage the library system.</p>
            <a asp-area="Librarian" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg">Go to Dashboard</a>
        }
    }
    else
    {
        <p>Please login or register to access the library system.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">Login</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">Register as Student</a>
    }
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Browse Books</h5>
                <p class="card-text">Explore our extensive collection of books across various categories.</p>
                <a asp-controller="Books" asp-action="Index" class="btn btn-sm btn-primary">View Books</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Easy Borrowing</h5>
                <p class="card-text">Request books online and pick them up from the library.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Track Your Loans</h5>
                <p class="card-text">Keep track of your borrowed books and due dates.</p>
            </div>
        </div>
    </div>
</div>
