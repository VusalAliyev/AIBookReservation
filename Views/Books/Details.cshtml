@model BookReservation.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="row fade-in">
    <div class="col-lg-4 mb-4">
        <div class="card shadow-lg">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="card-img-top" style="height: 500px; object-fit: cover;" alt="@Model.Title">
            }
            else
            {
                <div class="img-placeholder" style="height: 500px;">
                    <i class="bi bi-book"></i>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="card-title mb-2">@Model.Title</h2>
                <h4 class="text-muted mb-4">
                    <i class="bi bi-person-circle me-2"></i>by @Model.Author
                </h4>

                <div class="mb-4">
                    <span class="badge bg-secondary me-2 p-2">
                        <i class="bi bi-tag me-1"></i>@Model.Category?.Name
                    </span>
                    @if (Model.AvailableCount > 0)
                    {
                        <span class="badge bg-success p-2">
                            <i class="bi bi-check-circle me-1"></i>@Model.AvailableCount Available
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger p-2">
                            <i class="bi bi-x-circle me-1"></i>Not Available
                        </span>
                    }
                </div>

                <hr />

                <div class="row mb-3">
                    @if (!string.IsNullOrWhiteSpace(Model.ISBN))
                    {
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center p-3 bg-light rounded">
                                <i class="bi bi-upc-scan text-primary me-3" style="font-size: 1.5rem;"></i>
                                <div>
                                    <small class="text-muted d-block">ISBN</small>
                                    <strong>@Model.ISBN</strong>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="col-md-6 mb-3">
                        <div class="d-flex align-items-center p-3 bg-light rounded">
                            <i class="bi bi-collection text-success me-3" style="font-size: 1.5rem;"></i>
                            <div>
                                <small class="text-muted d-block">Total Copies</small>
                                <strong>@Model.TotalCount</strong>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="mt-4">
                        <h5 class="mb-3">
                            <i class="bi bi-journal-text me-2"></i>Description
                        </h5>
                        <p class="lead text-muted">@Model.Description</p>
                    </div>
                }

                <hr />

                <div class="mt-4">
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Student"))
                    {
                        @if (ViewBag.CanRequest == true && Model.AvailableCount > 0)
                        {
                            <form asp-controller="Requests" asp-action="Create" method="post">
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button type="submit" class="btn btn-success btn-lg w-100">
                                    <i class="bi bi-bookmark-plus me-2"></i>Request to Borrow
                                </button>
                            </form>
                        }
                        else if (Model.AvailableCount <= 0)
                        {
                            <button class="btn btn-secondary btn-lg w-100" disabled>
                                <i class="bi bi-x-circle me-2"></i>Not Available
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                <strong>Cannot Request:</strong> You may already have a pending request or an active loan for this book.
                            </div>
                        }
                    }
                    else if (User.Identity?.IsAuthenticated != true)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            Please <a asp-controller="Account" asp-action="Login" class="alert-link">login</a> to request this book.
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <a asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Books
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
