@model IEnumerable<BookReservation.Models.Loan>
@{
    ViewData["Title"] = "My Loan History";
}

<h2>My Loan History</h2>

@if (Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Book</th>
                <th>Author</th>
                <th>Issued Date</th>
                <th>Due Date</th>
                <th>Returned Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in Model)
            {
                var wasOverdue = loan.ReturnedDate.HasValue && loan.ReturnedDate.Value > loan.DueDate;
                <tr>
                    <td>@loan.Book?.Title</td>
                    <td>@loan.Book?.Author</td>
                    <td>@loan.IssuedDate.ToLocalTime().ToString("g")</td>
                    <td>@loan.DueDate.ToLocalTime().ToString("g")</td>
                    <td>@loan.ReturnedDate?.ToLocalTime().ToString("g")</td>
                    <td>
                        @if (wasOverdue)
                        {
                            <span class="badge bg-warning">Returned Late</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Returned On Time</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        You have no loan history yet.
    </div>
}
