@model IEnumerable<BookReservation.Models.Loan>
@{
    ViewData["Title"] = "Overdue Loans";
}

<h2 class="text-danger">Overdue Loans</h2>

<div class="mb-3">
    <a asp-action="Active" class="btn btn-primary">View All Active Loans</a>
</div>

@if (Model.Any())
{
    <div class="alert alert-warning">
        <strong>Warning!</strong> The following loans are overdue and need immediate attention.
    </div>
    
    <table class="table table-striped table-danger">
        <thead>
            <tr>
                <th>Student</th>
                <th>Book</th>
                <th>Author</th>
                <th>Issued Date</th>
                <th>Due Date</th>
                <th>Days Overdue</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in Model)
            {
                var daysOverdue = (int)(DateTime.UtcNow - loan.DueDate).TotalDays;
                <tr>
                    <td>@loan.Student?.FullName</td>
                    <td>@loan.Book?.Title</td>
                    <td>@loan.Book?.Author</td>
                    <td>@loan.IssuedDate.ToLocalTime().ToString("g")</td>
                    <td>@loan.DueDate.ToLocalTime().ToString("g")</td>
                    <td>
                        <span class="badge bg-danger">@daysOverdue days</span>
                    </td>
                    <td>
                        <form asp-action="Return" asp-route-id="@loan.Id" method="post" class="d-inline" onsubmit="return confirm('Mark this loan as returned?');">
                            <button type="submit" class="btn btn-sm btn-primary">Mark Returned</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-success">
        No overdue loans at this time!
    </div>
}
