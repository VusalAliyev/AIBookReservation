@model BookReservation.ViewModels.PaginatedList<BookReservation.Models.Book>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2><i class="bi bi-journals me-2"></i>Manage Books</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add New Book
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchTerm" class="form-control border-start-0" 
                           placeholder="Search by title or author..." value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>ISBN</th>
                        <th>Total</th>
                        <th>Available</th>
                        <th width="200">Actions</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Category?.Name</td>
                    <td>@book.ISBN</td>
                    <td>@book.TotalCount</td>
                    <td>
                        @if (book.AvailableCount > 0)
                        {
                            <span class="badge bg-success">@book.AvailableCount</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@book.AvailableCount</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@book.Id" method="post" class="d-inline" 
                              onsubmit="return confirm('Are you sure you want to delete this book?');">
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Book pagination" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" 
                       asp-action="Index" 
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchTerm="@ViewBag.SearchTerm">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                </li>

                @{
                    var startPage = Math.Max(1, Model.PageIndex - 2);
                    var endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                }

                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="1" asp-route-searchTerm="@ViewBag.SearchTerm">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                @for (var i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                    </li>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-searchTerm="@ViewBag.SearchTerm">@Model.TotalPages</a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" 
                       asp-action="Index" 
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchTerm="@ViewBag.SearchTerm">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>

            <div class="text-center text-muted">
                <small>
                    Showing @((Model.PageIndex - 1) * Model.PageSize + 1) - @(Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount)) of @Model.TotalCount books
                </small>
            </div>
        </nav>
    }
}
else
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-2"></i>
        @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
        {
            <text>No books found matching your search criteria.</text>
        }
        else
        {
            <text>No books in the system yet. Click "Add New Book" to get started.</text>
        }
    </div>
}
