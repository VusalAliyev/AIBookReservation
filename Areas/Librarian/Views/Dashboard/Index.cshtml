@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4 fade-in">
    <h2 class="mb-2">
        <i class="bi bi-speedometer2 me-2 text-ocean"></i>Librarian Dashboard
    </h2>
    <p class="text-muted">Welcome back! Here's your library overview for today.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-xl-3 col-md-6">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--ocean-blue) 0%, var(--dusky-blue) 100%);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-90">Total Books</p>
                    <h2 class="mb-2">@ViewBag.TotalBooks</h2>
                    <small class="opacity-90"><i class="bi bi-check-circle me-1"></i>@ViewBag.AvailableBooks available</small>
                </div>
                <div class="opacity-25">
                    <i class="bi bi-book-fill" style="font-size: 4rem;"></i>
                </div>
            </div>
            <a asp-controller="Books" asp-action="Index" class="btn btn-light mt-3 w-100">
                <i class="bi bi-journals me-2"></i>Manage Books
            </a>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--golden-yellow) 0%, #f39c12 100%);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1" style="color: var(--dark-text);">Pending Requests</p>
                    <h2 class="mb-2" style="color: var(--dark-text);">@ViewBag.PendingRequests</h2>
                    <small style="color: var(--dark-text);"><i class="bi bi-hourglass-split me-1"></i>Awaiting approval</small>
                </div>
                <div class="opacity-25">
                    <i class="bi bi-inbox-fill" style="font-size: 4rem; color: var(--dark-text);"></i>
                </div>
            </div>
            <a asp-controller="Requests" asp-action="Pending" class="btn btn-light mt-3 w-100" style="color: var(--dark-text);">
                <i class="bi bi-eye me-2"></i>Review Requests
            </a>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--success-green) 0%, #229954 100%);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-90">Active Loans</p>
                    <h2 class="mb-2">@ViewBag.ActiveLoans</h2>
                    <small class="opacity-90"><i class="bi bi-calendar-check me-1"></i>Currently borrowed</small>
                </div>
                <div class="opacity-25">
                    <i class="bi bi-bookmark-fill" style="font-size: 4rem;"></i>
                </div>
            </div>
            <a asp-controller="Loans" asp-action="Active" class="btn btn-light mt-3 w-100">
                <i class="bi bi-list-check me-2"></i>View Loans
            </a>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--danger-red) 0%, #c0392b 100%);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-90">Overdue Loans</p>
                    <h2 class="mb-2">@ViewBag.OverdueLoans</h2>
                    <small class="opacity-90"><i class="bi bi-exclamation-triangle me-1"></i>Needs attention</small>
                </div>
                <div class="opacity-25">
                    <i class="bi bi-alarm-fill" style="font-size: 4rem;"></i>
                </div>
            </div>
            <a asp-controller="Loans" asp-action="Overdue" class="btn btn-light mt-3 w-100">
                <i class="bi bi-exclamation-circle me-2"></i>View Overdue
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-lg h-100 fade-in">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-lightning-charge-fill me-2"></i>Quick Actions
                </h5>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Books" asp-action="Create" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                         style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--ocean-blue), var(--dusky-blue));">
                        <i class="bi bi-plus-circle text-white" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <strong class="d-block">Add New Book</strong>
                        <small class="text-muted">Expand your library collection</small>
                    </div>
                </a>
                <a asp-controller="Categories" asp-action="Index" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                         style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--dusky-blue), var(--ocean-blue));">
                        <i class="bi bi-tags text-white" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <strong class="d-block">Manage Categories</strong>
                        <small class="text-muted">Organize book classifications</small>
                    </div>
                </a>
                <a asp-controller="Students" asp-action="Index" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                         style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--success-green), #229954);">
                        <i class="bi bi-people text-white" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <strong class="d-block">View All Students</strong>
                        <small class="text-muted">Access student directory</small>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-lg h-100 fade-in" style="animation-delay: 0.1s;">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="bi bi-info-circle-fill me-2"></i>System Status
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="mb-4 p-3 rounded d-flex align-items-center" style="background: linear-gradient(135deg, #d5f4e6, #a8e6cf);">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 50px; height: 50px; background-color: var(--success-green);">
                        <i class="bi bi-check-circle-fill text-white" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <strong class="d-block text-success">System Online</strong>
                        <small class="text-muted">All services running normally</small>
                    </div>
                </div>

                @if (ViewBag.OverdueLoans > 0)
                {
                    <div class="mb-4 p-3 rounded d-flex align-items-center" style="background: linear-gradient(135deg, #fadbd8, #f8b4b4);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                             style="width: 50px; height: 50px; background-color: var(--danger-red);">
                            <i class="bi bi-exclamation-triangle-fill text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <div>
                            <strong class="d-block text-danger">Overdue Loans Alert</strong>
                            <small class="text-muted">@ViewBag.OverdueLoans loan(s) require immediate attention</small>
                        </div>
                    </div>
                }

                @if (ViewBag.PendingRequests > 0)
                {
                    <div class="p-3 rounded d-flex align-items-center" style="background: linear-gradient(135deg, #fcf3cf, #fdeaa8);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                             style="width: 50px; height: 50px; background-color: var(--golden-yellow);">
                            <i class="bi bi-clock-fill text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <div>
                            <strong class="d-block" style="color: #b9770e;">Pending Requests</strong>
                            <small class="text-muted">@ViewBag.PendingRequests request(s) awaiting review</small>
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-3 rounded d-flex align-items-center" style="background: linear-gradient(135deg, #d5f4e6, #a8e6cf);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                             style="width: 50px; height: 50px; background-color: var(--success-green);">
                            <i class="bi bi-check2-circle text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <div>
                            <strong class="d-block text-success">All Caught Up!</strong>
                            <small class="text-muted">No pending requests at this time</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
